{
  "Routes": [
    // 1. Tuyến đường dành cho IdentityService (Đăng ký, Đăng nhập)
    {
      "DownstreamPathTemplate": "/api/auth/{catchAll}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7201 // <-- THAY BẰNG CỔNG CỦA IDENTITY SERVICE
        }
      ],
      "UpstreamPathTemplate": "/gateway/auth/{catchAll}",
      "UpstreamHttpMethod": [ "Post" ]
    },
    // 2. Tuyến đường dành cho JobService (Các nghiệp vụ còn lại)
    {
      "DownstreamPathTemplate": "/{catchAll}",
      "DownstreamScheme": "https",
      "DownstreamHostAndPorts": [
        {
          "Host": "localhost",
          "Port": 7004
        }
      ],
      "UpstreamPathTemplate": "/gateway/{catchAll}",
      "UpstreamHttpMethod": [ "Get", "Post", "Put", "Delete" ]
    }
  ],
  "GlobalConfiguration": {
    "BaseUrl": "https://localhost:7255"
  }
}